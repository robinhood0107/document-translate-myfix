{
  "name": "ocr-simpletest-japan-mangalmm-gemma4",
  "description": "Simpletest 3-page full-pipeline candidate using MangaLMM with the current promoted Gemma4 runtime.",
  "app": {
    "translator": "Custom Local Server(Gemma)",
    "ocr": "MangaLMM",
    "detector": "RT-DETR-v2",
    "inpainter": "lama_large_512px",
    "use_gpu": true,
    "extra_context": "",
    "hd_strategy": {
      "strategy": "Resize",
      "resize_limit": 960
    }
  },
  "gemma": {
    "image": "ghcr.io/ggml-org/llama.cpp:server-cuda",
    "pull_policy": "always",
    "endpoint_url": "http://127.0.0.1:18080/v1",
    "model": "gemma-4-26B-IQ4_NL.gguf",
    "model_path": "/models/gemma-4-26B-IQ4_NL.gguf",
    "context_size": 4096,
    "n_parallel": 1,
    "threads": 10,
    "n_gpu_layers": 23,
    "chunk_size": 6,
    "temperature": 0.7,
    "top_k": 64,
    "top_p": 0.95,
    "min_p": 0.0,
    "max_completion_tokens": 512,
    "request_timeout_sec": 180,
    "raw_response_logging": false,
    "reasoning": "off",
    "reasoning_budget": 0,
    "reasoning_format": "none",
    "response_format_mode": "json_schema",
    "response_schema_mode": "blocks"
  },
  "mangalmm_ocr_client": {
    "server_url": "http://127.0.0.1:28081/v1",
    "max_completion_tokens": 256,
    "parallel_workers": 1,
    "request_timeout_sec": 60,
    "raw_response_logging": false,
    "safe_resize": true,
    "max_pixels": 1200000,
    "max_long_side": 1280
  },
  "ocr_runtime": {
    "kind": "mangalmm",
    "image": "ghcr.io/ggml-org/llama.cpp:server-cuda",
    "pull_policy": "always",
    "model_path": "/models/MangaLMM.Q8_0.gguf",
    "mmproj_path": "/models/MangaLMM.mmproj-Q8_0.gguf",
    "context_size": 4096,
    "n_parallel": 1,
    "threads": 12,
    "n_gpu_layers": 99
  },
  "mask_refiner_settings": {
    "mask_refiner": "ctd",
    "keep_existing_lines": true,
    "ctd_detect_size": 1280,
    "ctd_det_rearrange_max_batches": 4,
    "ctd_device": "cuda",
    "ctd_font_size_multiplier": 1.0,
    "ctd_font_size_max": -1,
    "ctd_font_size_min": -1,
    "ctd_mask_dilate_size": 2
  },
  "inpainter_runtime": {
    "device": "cuda",
    "inpaint_size": 1536,
    "precision": "bf16"
  },
  "export": {
    "export_raw_text": false,
    "export_translated_text": true,
    "export_inpainted_image": false,
    "export_detector_overlay": false,
    "export_raw_mask": false,
    "export_mask_overlay": false,
    "export_cleanup_mask_delta": false,
    "export_debug_metadata": false
  }
}
